{
  "name": "accuraai-backend",
  "version": "1.0.0",
  "description": "Stack: Node.js, Express, TypeScript, TypeORM, Postgres (Docker), Zod, Swagger",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "start": "node dist/server.js",
    "build": "tsc",
    "vercel-build": "npm run build",
    "typeorm": "node --require ts-node/register ./node_modules/typeorm/cli.js -d ./src/db/data-source.ts",
    "m:run": "npm run typeorm -- migration:run",
    "m:revert": "npm run typeorm -- migration:revert",
    "m:show": "npm run typeorm -- migration:show",
    "migration:generate": "node -r ts-node/register ./node_modules/typeorm/cli.js migration:generate -d ./src/data-source.ts ./src/db/migrations/auto",
    "migration:run": "node -r ts-node/register ./node_modules/typeorm/cli.js migration:run -d ./src/db/data-source.ts",
    "migration:revert": "node -r ts-node/register ./node_modules/typeorm/cli.js migration:revert -d ./src/db/data-source.ts",
    "migration:show": "node -r ts-node/register ./node_modules/typeorm/cli.js migration:show -d ./src/db/data-source.ts",
    "swagger:export": "ts-node ./scripts/swagger-export.ts",
    "swagger:print": "ts-node src/swagger.ts > openapi.json",
    "lint": "eslint . --ext .ts",
    "migrate:create": "node -r ts-node/register node_modules/typeorm/cli.js migration:create src/db/migrations/20250912133937",
    "migrate:gen": "node -r ts-node/register node_modules/typeorm/cli.js migration:generate -d src/db/data-source.ts src/db/migrations/auto",
    "migrate:run": "node -r ts-node/register node_modules/typeorm/cli.js migration:run -d src/db/data-source.ts",
    "migrate:revert": "node -r ts-node/register node_modules/typeorm/cli.js migration:revert -d src/db/data-source.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^7.1.0",
    "@aws-sdk/client-s3": "^3.901.0",
    "@aws-sdk/client-sts": "^3.888.0",
    "@aws-sdk/s3-request-presigner": "^3.906.0",
    "@cedrugs/pdf-parse": "^1.0.0",
    "@dqbd/tiktoken": "^1.0.22",
    "archiver": "^7.0.1",
    "bcryptjs": "^3.0.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "docxtemplater": "^3.66.6",
    "dotenv": "^17.2.3",
    "exceljs": "^4.4.0",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.11.0",
    "mime-types": "^3.0.1",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "node-cron": "^4.2.1",
    "nodemailer": "^7.0.10",
    "openai": "^6.27.0",
    "pdf-lib": "^1.17.1",
    "pdf-poppler": "^0.2.3",
    "pdfjs-dist": "^3.11.174",
    "pg": "^8.16.3",
    "pizzip": "^3.2.0",
    "puppeteer": "^24.23.0",
    "reflect-metadata": "^0.2.2",
    "scribe.js-ocr": "^0.10.0",
    "speakeasy": "^2.0.0",
    "swagger-ui-express": "^5.0.1",
    "tesseract.js": "^6.0.1",
    "typeorm": "^0.3.26",
    "undici": "^7.16.0",
    "unzipper": "^0.12.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/archiver": "^6.0.3",
    "@types/bcryptjs": "^3.0.0",
    "@types/cookie-parser": "^1.4.9",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mime-types": "^3.0.1",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.7.2",
    "@types/nodemailer": "^7.0.3",
    "@types/pg": "^8.15.6",
    "@types/speakeasy": "^2.0.10",
    "@types/swagger-ui-dist": "^3.30.6",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/unzipper": "^0.10.11",
    "@typescript-eslint/eslint-plugin": "^8.43.0",
    "@typescript-eslint/parser": "^8.43.0",
    "cross-env": "^10.1.0",
    "eslint": "^9.35.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typeorm-ts-node-commonjs": "^0.3.20",
    "typescript": "^5.9.3"
  }
}
